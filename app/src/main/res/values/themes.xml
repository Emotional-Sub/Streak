<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Streak" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/streak_primary</item>
        <item name="colorPrimaryVariant">@color/streak_primary_dark</item>
        <item name="colorSecondary">@color/streak_accent</item>
        <item name="colorOnPrimary">@color/streak_on_primary</item>
        <item name="android:colorBackground">@color/streak_bg</item>
        <item name="colorSurface">@color/streak_surface</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/streak_primary</item>
        <item name="materialButtonStyle">@style/Widget.Streak.Button</item>
        <item name="textInputStyle">@style/Widget.Streak.TextInputLayout</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <!-- windowLayoutInDisplayCutoutMode 是 API 28 才有的属性，minSdk 26 下低版本运行时
             会忽略它（纯刘海区延展的装饰属性，无功能影响）。用 tools:targetApi 消除 lint NewApi 错误。 -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="28">shortEdges</item>
    </style>
</resources>
