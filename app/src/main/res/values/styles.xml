<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.Streak.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="backgroundTint">@color/streak_primary</item>
    </style>

    <style name="Widget.Streak.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">18dp</item>
        <item name="strokeColor">@color/streak_line</item>
        <item name="android:textColor">@color/streak_primary</item>
    </style>

    <style name="Widget.Streak.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="boxStrokeColor">@color/streak_primary</item>
        <item name="hintTextColor">@color/streak_muted</item>
    </style>

    <style name="Widget.Streak.TextInputLayout.ExposedDropdownMenu" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="boxStrokeColor">@color/streak_primary</item>
        <item name="hintTextColor">@color/streak_muted</item>
    </style>

    <style name="CalendarWeekdayStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/streak_muted</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="StreakShapeCornerMedium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="StreakShapeCircle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
