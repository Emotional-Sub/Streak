<?xml version="1.0" encoding="utf-8"?>
<!-- 打卡录入底部弹层：心情(1~5) + 耗时(分钟) + 照片 + 备注。全部可选，留空即「快速打卡」。 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_sheet_handle" />

        <TextView
            android:id="@+id/tvCheckInTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/habit_title_placeholder"
            android:textColor="@color/streak_ink"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- 心情：5 个表情按钮，点选高亮，再点取消（回到未记录） -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/checkin_mood_label"
            android:textColor="@color/streak_text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:weightSum="5">

            <TextView
                android:id="@+id/tvMood1"
                style="@style/CheckInMoodEmoji"
                android:text="@string/checkin_mood_emoji_1" />

            <TextView
                android:id="@+id/tvMood2"
                style="@style/CheckInMoodEmoji"
                android:text="@string/checkin_mood_emoji_2" />

            <TextView
                android:id="@+id/tvMood3"
                style="@style/CheckInMoodEmoji"
                android:text="@string/checkin_mood_emoji_3" />

            <TextView
                android:id="@+id/tvMood4"
                style="@style/CheckInMoodEmoji"
                android:text="@string/checkin_mood_emoji_4" />

            <TextView
                android:id="@+id/tvMood5"
                style="@style/CheckInMoodEmoji"
                android:text="@string/checkin_mood_emoji_5" />
        </LinearLayout>

        <!-- 耗时：分钟数字输入 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/checkin_duration_hint"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            app:suffixText="@string/checkin_duration_suffix"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCheckInDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="4" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 备注 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/checkin_note_hint"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCheckInNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 照片：预览 + 拍照/相册/移除 -->
        <ImageView
            android:id="@+id/ivCheckInPhoto"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="14dp"
            android:contentDescription="@string/cd_checkin_photo"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckInTakePhoto"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="@string/action_take_photo"
                android:textAllCaps="false"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckInPickPhoto"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/action_gallery"
                android:textAllCaps="false"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckInRemovePhoto"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:text="@string/editor_remove_photo"
            android:textAllCaps="false"
            android:visibility="gone" />

        <!-- 操作：跳过（不带附加信息直接打卡）/ 保存 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckInSkip"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="@string/action_skip"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckInSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/action_save"
                android:textAllCaps="false"
                app:cornerRadius="18dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
