<?xml version="1.0" encoding="utf-8"?>
<!-- 打卡时间线单条：日期 + 心情表情/耗时元信息 + 备注 + 打卡照片缩略图。 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvNoteDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/stat_row_label_placeholder"
            android:textColor="@color/streak_text_faint"
            android:textSize="12sp" />

        <!-- 心情表情 + 耗时：无数据时 GONE -->
        <TextView
            android:id="@+id/tvNoteMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/streak_muted"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvNoteText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/stat_row_value_placeholder"
        android:textColor="@color/streak_text_primary"
        android:textSize="15sp" />

    <ImageView
        android:id="@+id/ivNotePhoto"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_marginTop="8dp"
        android:contentDescription="@string/cd_checkin_photo"
        android:scaleType="centerCrop"
        android:visibility="gone" />
</LinearLayout>
