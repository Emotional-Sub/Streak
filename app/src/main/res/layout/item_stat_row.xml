<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="40dp"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/tvStatLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/stat_row_label_placeholder"
        android:textColor="@color/streak_text_faint"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvStatValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/stat_row_value_placeholder"
        android:textColor="@color/streak_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
