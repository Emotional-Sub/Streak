    <color name="streak_surface_alt">#242833</color>
    <color name="streak_line">#333849</color>

    <!-- 品牌主色在深色下略微提亮，保证对比度 -->
    <color name="streak_primary">#8A8DF5</color>
    <color name="streak_primary_dark">#6C6FE8</color>
    <color name="streak_primary_soft">#2A2C46</color>
