<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- 扫码需要相机；拍照(ACTION_IMAGE_CAPTURE)在清单声明 CAMERA 后也需运行时授权 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- 保存二维码到相册：仅 Android 9(API 28) 及以下需要写外部存储；
         API 29+ 走 MediaStore 分区存储，无需此权限 -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".StreakApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Streak">

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <receiver
            android:name=".reminder.ReminderReceiver"
            android:exported="false" />

        <receiver
            android:name=".reminder.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".widget.StreakWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/streak_widget_info" />
        </receiver>

        <activity
            android:name=".ui.HabitEditorActivity"
            android:exported="false"
            android:theme="@style/Theme.Streak" />

        <activity
            android:name=".ui.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.Streak" />

        <activity
            android:name=".ui.ProfileEditActivity"
            android:exported="false"
            android:theme="@style/Theme.Streak" />

        <activity
            android:name=".ui.BadgeWallActivity"
            android:exported="false"
            android:theme="@style/Theme.Streak" />

        <activity
            android:name=".ui.PortraitCaptureActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true"
            android:theme="@style/Theme.Streak" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Streak">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
