# Release 签名凭据模板：复制为项目根目录的 keystore.properties（该文件已被 .gitignore 忽略），
# 填入真实值后即可本地打 release 包。也可改用环境变量：
#   STREAK_STORE_FILE / STREAK_STORE_PASSWORD / STREAK_KEY_ALIAS / STREAK_KEY_PASSWORD
# 二者任一齐全（keystore 文件存在 + 两个密码）即启用 release 签名。
#
# 注意：原仓库曾硬编码密码 streak123，请轮换 keystore 密码后再填入此处。
storeFile=release/streak-release.jks
storePassword=CHANGE_ME
keyAlias=streak
keyPassword=CHANGE_ME
